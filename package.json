{
  "name": "ssm-foundations",
  "description": "A lens-led 17-chapter foundations book for post-transformer sequence-model architectures (SSMs, delta-rule, gating, hybrids). Dynamical-systems perspective foregrounded.",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "predev": "npm run build:bib --if-present && npm run build:labels --if-present",
    "prevalidate": "npm run build:bib && npm run build:labels --if-present",
    "prebuild": "npm run validate",
    "build:bib": "book-scaffold build-bib",
    "build:labels": "book-scaffold build-labels",
    "build:figures": "book-scaffold build-figures",
    "build:notebooks": "book-scaffold render-notebooks",
    "validate": "book-scaffold validate",
    "dev": "astro dev",
    "build": "astro build && pagefind --site dist",
    "preview": "astro preview",
    "dev:cf": "wrangler dev",
    "deploy": "wrangler deploy"
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.3",
    "@astrojs/preact": "^5.1.1",
    "@brandon_m_behring/book-scaffold-astro": "^4.23.0",
    "astro": "^6.4.6",
    "katex": "^0.16.11",
    "preact": "^10.29.1",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0"
  },
  "devDependencies": {
    "wrangler": "^4.93.1"
  }
}
